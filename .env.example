# ---- Database ----
# Local dev ใช้ SQLite ได้ทันที / Production แนะนำ PostgreSQL (Supabase / Neon)
DATABASE_URL="file:./dev.db"

# ---- Auth ----
# สร้างด้วย: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET="change-me-to-a-long-random-hex-string"

# ---- Anthropic API (optional) ----
# ถ้าไม่ใส่ ระบบจะใช้ตัวเรียบเรียงรายงานภาษาไทยแบบ template (deterministic)
# และข้ามการอ่านโหงวเฮ้งจากรูป
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-5"

# ---- App ----
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---- Cron (retention job) ----
# ป้องกัน endpoint ลบรูปถ่ายตามอายุการเก็บ (PDPA) — Vercel Cron แนบเป็น Bearer token
# สร้างด้วย: node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
CRON_SECRET=""

# ---- Admin bootstrap (ใช้ตอน seed) ----
ADMIN_EMAIL="admin@minghe.local"
ADMIN_PASSWORD="minghe-admin-2026"
